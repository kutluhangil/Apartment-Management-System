# Backend Environment Variables

# ─── Local Development ────────────────────────────────────────────────────────
# Leave TURSO_* empty to use local SQLite file (./data/apartment.db)

# ─── Production (Turso) ──────────────────────────────────────────────────────
# Get these from: https://turso.tech (free tier available)
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-auth-token-here

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string-in-production

# Seed kullanıcıları (Güvenlik için şifrelerin boş bırakılmaması gerekir)
MANAGER_EMAIL=murat@cumhuriyet.com
MANAGER_PASSWORD=yönetici_şifresi_yazın
ADMIN_EMAIL=kutluhan@cumhuriyet.com
ADMIN_PASSWORD=admin_şifresi_yazın

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001

# ─── CORS ───────────────────────────────────────────────────────────────────-
# Your Vercel frontend URL (set this in Vercel dashboard too)
FRONTEND_URL=https://your-app.vercel.app

# ─── Apartman Bilgileri (Public Settings) ──────────────────────────────────-
# Bu bilgiler ana sayfada IBAN kartında görünür
APARTMENT_IBAN=TR00 0000 0000 0000 0000 0000 00
APARTMENT_ACCOUNT_NAME=Cumhuriyet Apartmanı Yönetimi
APARTMENT_BANK_NAME=
APARTMENT_PAYMENT_NOTE=Daire {No} - {Ay} {Yıl} Aidatı
APARTMENT_CONTACT_EMAIL=murat@cumhuriyet.com

# ─── Cloud Storage (Vercel Blob) ───────────────────────────────────────────-
# Set bu set edilirse fatura/belge dosyaları bulutta tutulur, sunucu çökse bile
# Token: https://vercel.com/dashboard → Storage → Blob → Create token
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxx

# ─── Aidat Hatırlatma (Telegram) ───────────────────────────────────────────-
# @BotFather'dan bot oluşturun, token alın. Apartman grubuna botu ekleyip ID alın.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# ─── Aidat Hatırlatma (Webhook — Discord/Slack/Custom) ─────────────────────-
# Discord webhook veya benzeri her şey çalışır
# REMINDER_WEBHOOK_URL=
